# ── LLM Config ──
# For local development (free) — no key needed, just run: ollama pull llama3
OLLAMA_MODEL=llama3

# For production/demo — uncomment and add your key
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Embedding Config ──
# Default: runs locally via sentence-transformers (free)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store ──
CHROMA_PERSIST_DIR=./chroma_db

# ── Job Search (Project 2, Step 6) ──
# SERPAPI_KEY=your-key-here
